# Modbus Configuration (Waveshare RS485-TO-WIFI-ETH defaults)
MODBUS_MODE=tcp
MODBUS_TCP_HOST=127.0.0.1      # simulator: 127.0.0.1 / real: 192.168.0.7
MODBUS_TCP_PORT=502
MODBUS_RTU_PORT=COM3
MODBUS_BAUDRATE=9600
MODBUS_TIMEOUT=3

# Register Map
REGISTER_MAP_FILE=register_maps/chiller_default.yaml

# Database
DATABASE_URL=sqlite+aiosqlite:///./chiller.db

# Security
SECRET_KEY=dev-secret-key-change-in-production

# CORS (allow all for development)
ALLOWED_ORIGINS=["*"]
